config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Huashan Sword Tournament"
config/description="A Godot 4 wuxia RPG combat demo: Huashan Sword Tournament (华山论剑). Player controls Yang Guo against the Five Greats in real-time-with-pause grid-based combat."
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.7")

[autoload]

GameManager="*res://scripts/autoload/game_manager.gd"
GridManager="*res://scripts/autoload/grid_manager.gd"
CombatManager="*res://scripts/autoload/combat_manager.gd"
TutorialManager="*res://scripts/autoload/tutorial_manager.gd"

